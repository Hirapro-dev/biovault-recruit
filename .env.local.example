# Resend の API キー（https://resend.com のダッシュボードで発行）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 通知メールの送信先（応募が届くメールアドレス）
RECRUIT_NOTIFY_TO=recruit@biovault.co.jp,tominaga@ltj-inc.co.jp

# 送信元アドレス（Resend で認証済みのドメインのアドレスのみ指定可能）
# - 動作確認のみ: onboarding@resend.dev（Resend アカウントのメール宛にしか送れない）
# - 本番運用: Resend の Domains で DNS 認証後に指定（例: recruit@biovault.co.jp）
# ※ RESEND_FROM のドメインが Resend 未認証だと 502「メール送信に失敗」になります
RESEND_FROM=recruit@biovault.co.jp

# Vercel Blob のトークン（顔写真の保存・公開URL発行用）
# Vercel ダッシュボードで Blob ストアを作成すると自動付与されます。
# ローカルでは `vercel env pull` で取得、または Blob ストアの設定からコピーしてください。
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
